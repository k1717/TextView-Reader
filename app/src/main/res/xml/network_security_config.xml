<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- The app is designed as an offline local reader. Cleartext HTTP is disabled
         as defense in depth in case a future build adds network permission. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
