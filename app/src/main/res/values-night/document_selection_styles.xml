<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night variant of the document/Word viewer theme.
         Intentionally does not override textSelectHandle or ActionMode background,
         so WebView keeps native Android/Samsung selection handles and toolbar. -->
    <style name="Theme.SimpleTextReader.DocumentSelectionContrast" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_dark_primary</item>
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_dark_primaryContainer</item>
        <item name="colorSurface">@color/md_theme_dark_surface</item>
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_dark_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_dark_outline</item>
        <item name="android:textColorPrimary">@color/md_theme_dark_onSurface</item>
        <item name="android:textColorSecondary">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="colorControlNormal">@color/md_theme_dark_onSurfaceVariant</item>
        <item name="colorControlActivated">@color/md_theme_dark_onSurface</item>
        <item name="android:windowBackground">@color/md_theme_dark_surface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
</resources>
