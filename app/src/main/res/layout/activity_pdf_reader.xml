<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pdf_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/pdf_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#000000"
            app:titleTextColor="#FFFFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/pdf_viewport"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#202124">

        <HorizontalScrollView
            android:id="@+id/pdf_h_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <ScrollView
                android:id="@+id/pdf_v_scroll"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <ImageView
                    android:id="@+id/pdf_page_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:adjustViewBounds="true"
                    android:background="#FFFFFFFF"
                    android:contentDescription="@string/pdf_page"
                    android:padding="0dp" />

            </ScrollView>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/pdf_continuous_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/pdf_progress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminate="true" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/pdf_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#DD000000"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/pdf_page_status"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:gravity="center"
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/pdf_prev"
                style="@style/ReaderBottomButton"
                android:drawableTop="@drawable/ic_bottom_arrow_left"
                android:text="@string/previous_page" />

            <TextView
                android:id="@+id/pdf_next"
                style="@style/ReaderBottomButton"
                android:drawableTop="@drawable/ic_bottom_arrow_right"
                android:text="@string/next_page" />

            <TextView
                android:id="@+id/pdf_slide_toggle"
                style="@style/ReaderBottomButton"
                android:text="" />

            <TextView
                android:id="@+id/pdf_page"
                style="@style/ReaderBottomButton"
                android:drawableTop="@drawable/ic_bottom_page"
                android:text="@string/bottom_page" />

            <TextView
                android:id="@+id/pdf_bookmark"
                style="@style/ReaderBottomButton"
                android:drawableTop="@drawable/ic_bottom_bookmark"
                android:text="@string/bookmark" />

            <TextView
                android:id="@+id/pdf_zoom_more"
                style="@style/ReaderBottomButton"
                android:drawableTop="@drawable/ic_bottom_more_horiz"
                android:text="@string/more" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
