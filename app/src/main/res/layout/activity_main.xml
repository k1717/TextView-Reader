<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <FrameLayout
        android:id="@+id/main_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface">

        <LinearLayout
            android:id="@+id/main_stack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface"
            android:orientation="vertical">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/main_appbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorPrimary"
            android:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:titleTextColor="?attr/colorOnPrimary" />

        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:id="@+id/path_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceVariant"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/current_path"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="start"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/parent_folder_button"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/parent_folder"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:singleLine="true"
                android:text="@string/parent_folder_short"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Recent files view (home) -->
        <LinearLayout
            android:id="@+id/recent_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="?attr/colorSurface"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/recent_header_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurface"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="8dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/recent_section_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/recently_read"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/recent_clear_all"
                    android:layout_width="52dp"
                    android:layout_height="34dp"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="@string/clear_all"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="invisible" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/recent_content_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <com.textview.reader.view.TinyPartialItemClipRecyclerView
                    android:id="@+id/recent_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSurface"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="none" />

                <TextView
                    android:id="@+id/recent_empty_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:padding="32dp"
                    android:text="@string/no_recent_files"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/recent_fast_scroll_rail"
                    android:layout_width="32dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="false"
                    android:paddingEnd="4dp"
                    android:visibility="gone">

                    <View
                        android:id="@+id/recent_fast_scroll_thumb"
                        android:layout_width="8dp"
                        android:layout_height="48dp"
                        android:layout_gravity="end"
                        android:background="@drawable/fastscroll_thumb" />

                </FrameLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- File browser view (folder navigation) -->
        <FrameLayout
            android:id="@+id/main_content_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="?attr/colorSurface"
            android:clipToPadding="false"
            android:visibility="gone">

            <com.textview.reader.view.TinyPartialItemClipRecyclerView
                android:id="@+id/file_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/colorSurface"
                android:clipToPadding="false"
                android:scrollbars="none" />

            <TextView
                android:id="@+id/empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:padding="32dp"
                android:text="@string/no_text_files_found"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/file_fast_scroll_rail"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="false"
                android:paddingEnd="4dp"
                android:visibility="gone">

                <View
                    android:id="@+id/file_fast_scroll_thumb"
                    android:layout_width="8dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end"
                    android:background="@drawable/fastscroll_thumb" />

            </FrameLayout>

        </FrameLayout>

        <LinearLayout
            android:id="@+id/file_search_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp">

            <HorizontalScrollView
                android:id="@+id/file_type_filter_scroll"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/file_type_filter_row"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="1dp"
                    android:paddingEnd="1dp">

                    <TextView
                        android:id="@+id/filter_all"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:layout_marginEnd="0dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/file_filter_all"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filter_general"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="0dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/file_filter_general"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filter_txt"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="0dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/file_filter_txt"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filter_archive"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="0dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/file_filter_archive"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filter_pdf"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="0dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/file_filter_pdf"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filter_epub"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="0dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/file_filter_epub"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filter_word"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/file_filter_word"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filter_img"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/file_filter_img"
                        android:textSize="12sp" />

                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="4dp">

                <EditText
                    android:id="@+id/file_search_input"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="?attr/colorSurfaceVariant"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="8dp"
                    android:hint="@string/file_search_live_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/file_search_scope_button"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/search_scope_current_folder_only"
                    android:padding="8dp"
                    android:scaleType="center"
                    android:stateListAnimator="@null"
                    android:src="@drawable/ic_folder" />

                <ImageButton
                    android:id="@+id/file_sort_button"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/sort"
                    android:padding="8dp"
                    android:scaleType="center"
                    android:stateListAnimator="@null"
                    android:src="@drawable/ic_sort" />

                <TextView
                    android:id="@+id/file_search_clear_button"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="2dp"
                    android:gravity="center"
                    android:text="&#215;"
                    android:textSize="24sp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/file_search_progress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone" />

        <View
            android:id="@+id/drawer_edge_grabber"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Navigation drawer -->
    <include
        android:id="@+id/nav_drawer"
        layout="@layout/nav_drawer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
