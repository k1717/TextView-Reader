<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Scrollable top section: Recent folders only. -->
    <TextView
        android:id="@+id/drawer_recent_folders_title"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/recent_folders"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/drawer_storage_list"
        android:layout_width="match_parent"
        android:layout_height="336dp"
        android:background="?attr/colorSurface"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="true"
        android:overScrollMode="ifContentScrolls"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="?attr/colorOutline" />

    <!-- Scrollable middle section: Recent, Internal, SD, Downloads, added shortcuts. Java keeps this at 5 full rows and fills missing rows with shortcut placeholders. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/drawer_fixed_list"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="?attr/colorSurface"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="true"
        android:overScrollMode="ifContentScrolls"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="?attr/colorOutline" />

    <!-- Flexible blank area lives outside the scrollable lists, so list borders never show partial/blank rows. -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom action buttons remain fixed. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/drawer_btn_open_file"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_open_file"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_open_file"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/drawer_btn_bookmarks"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_bookmark"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_bookmarks"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/drawer_btn_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_settings"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
