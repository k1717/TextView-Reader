<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SimpleTextReader" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="android:textColorPrimary">@color/md_theme_light_onSurface</item>
        <item name="android:textColorSecondary">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorControlNormal">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorControlActivated">@color/md_theme_light_onSurface</item>
        <item name="android:windowBackground">@color/md_theme_light_surface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!--
            Override Samsung One UI 6+'s default text-selection handle drawables
            (which render as a flat hollow pill that looks broken against custom
            reader theme backgrounds) with classic AOSP Material teardrop shapes.
            These attributes are picked up by every Editor in this app's window
            tree, including WebView's selection editor in the document viewer
            and EditText fields in the reader dialogs.
        -->
        <item name="android:textSelectHandle">@drawable/text_select_handle_middle</item>
        <item name="android:textSelectHandleLeft">@drawable/text_select_handle_left</item>
        <item name="android:textSelectHandleRight">@drawable/text_select_handle_right</item>

        <!--
            Floating selection toolbar background. Force a consistent dark "black
            bubble" appearance regardless of system day/night mode so it always
            reads cleanly above the document content.
        -->
        <item name="actionModeBackground">@drawable/selection_action_mode_bubble</item>
        <item name="android:actionModeBackground">@drawable/selection_action_mode_bubble</item>
    </style>
</resources>
